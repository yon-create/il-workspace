# Operator master tokens — copy this file to operator/.env and fill in.
# operator/.env is git-ignored. NEVER commit real tokens.
# These are the ONLY accounts that ever face a CAPTCHA — you sign up once,
# then every client is stamped out from here.

# --- Supabase (Account > Access Tokens; Org settings > General for the org id) ---
SUPABASE_PAT=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_ORG_ID=your_org_id
SUPABASE_REGION=us-east-1
# free until 2 projects/org, then a paid org (~$10/project/mo). See operator/README.md.
SUPABASE_PLAN=free

# --- Vercel (Account Settings > Tokens; team id from team settings, omit for personal) ---
VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VERCEL_TEAM_ID=

# --- Shared service keys (one set reused across clients in the "lite" model) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Domains: the parent domain you own. Each client gets <slug>.<this> unless
#     you pass --domain= on the command line. DNS for this zone lives in ONE place
#     you control (Vercel/Cloudflare). ---
OPERATOR_PARENT_DOMAIN=il-clients.com

# --- Optional: Lark team notifications (shared operator app, or leave blank) ---
LARK_APP_ID=
LARK_APP_SECRET=
LARK_WEBHOOK_URL=
